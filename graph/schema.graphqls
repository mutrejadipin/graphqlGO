# GraphQL schema example
#
# https://gqlgen.com/getting-started/

# type Todo {
#   id: ID!
#   text: String!
#   done: Boolean!
#   user: User!
# }

type User {
  id: ID!
  name: String!
  email: String!
}

type Query {
  users: [User!]!
}

# input NewTodo {
#   text: String!
#   userId: String!
# }

type Mutation {
  createUser(name: String!, email: String!): User!
  deleteUser(id: ID!): User!
}
